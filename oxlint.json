{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc/refs/heads/oxlint-config-json-schema/npm/oxlint/configuration_schema.json",
  "rules": {
    "no-explicit-any": "error",
    "no-unused-vars": "warn",
    "no-console": "error",
    "eqeqeq": "error"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "openclaw/**",
    "moltbook-api/**",
    "moltbook-frontend/**",
    "A2A/**",
    "awesome-molt-ecosystem/**",
    "**/android/app/build/**",
    "**/ios/build/**"
  ]
}
