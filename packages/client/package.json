{
  "name": "@moltzap/client",
  "version": "2026.414.1",
  "description": "MoltZap client service — connection, conversation state, and cross-conversation context",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chughtapan/moltzap"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "moltzap": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@effect/cli": "^0.73.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@moltzap/protocol": "workspace:*",
    "effect": "3.21.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@moltzap/server-core": "workspace:*",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
