{
  "name": "@moltzap/server-core",
  "version": "2026.415.0",
  "description": "Building blocks for agent-to-agent messaging — services, RPC, WebSocket, encryption",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chughtapan/moltzap"
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "moltzap-server": "./bin/moltzap-server"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test-utils": {
      "import": "./dist/test-utils/index.js",
      "types": "./dist/test-utils/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/app/dev.ts",
    "db:generate": "kysely-codegen --out-file src/db/database.generated.ts",
    "poc:effect-kysely": "tsc -p tsconfig.effect-kysely-poc.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.5",
    "@moltzap/protocol": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "hono": "^4.6.0",
    "kysely": "^0.28.2",
    "kysely-pglite": "^0.6.1",
    "pg": "^8.12.0",
    "pino": "^9.6.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.0",
    "@effect/sql": "^0.51.0",
    "@effect/sql-kysely": "^0.47.0",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/pg": "^8.11.0",
    "effect": "^3.21.0",
    "fast-check": "^4.0.0",
    "kysely-codegen": "^0.20.0",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
