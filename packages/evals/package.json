{
  "name": "@moltzap/evals",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "eval:e2e": "tsx src/e2e-infra/index.ts",
    "agents": "tsx src/runtimes/cli.ts",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "build:docker": "bash scripts/build-eval-agent.sh"
  },
  "exports": {
    "./logger": {
      "import": "./dist/e2e-infra/logger.js",
      "types": "./dist/e2e-infra/logger.d.ts"
    },
    "./types": {
      "import": "./dist/e2e-infra/types.js",
      "types": "./dist/e2e-infra/types.d.ts"
    },
    "./judgment-bundle": {
      "import": "./dist/e2e-infra/judgment-bundle.js",
      "types": "./dist/e2e-infra/judgment-bundle.d.ts"
    },
    "./telemetry": {
      "import": "./dist/e2e-infra/telemetry.js",
      "types": "./dist/e2e-infra/telemetry.d.ts"
    },
    "./runtimes": {
      "import": "./dist/runtimes/index.js",
      "types": "./dist/runtimes/index.d.ts"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@sinclair/typebox": "^0.34.0",
    "dotenv": "^16.0.0",
    "effect": "^3.21.0",
    "js-yaml": "^4.0.0",
    "pg": "^8.13.0",
    "winston": "^3.0.0",
    "yargs": "^17.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@moltzap/client": "workspace:*",
    "@moltzap/openclaw-channel": "workspace:*",
    "@moltzap/protocol": "workspace:*",
    "@moltzap/server-core": "workspace:*",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/js-yaml": "^4.0.0",
    "@types/pg": "^8.11.0",
    "@types/yargs": "^17.0.0",
    "kysely": "^0.28.2",
    "openclaw": "2026.3.31",
    "testcontainers": "^10.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
