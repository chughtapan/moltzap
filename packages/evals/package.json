{
  "name": "@moltzap/evals",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "eval:e2e": "tsx src/e2e-infra/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "build:docker": "bash scripts/build-eval-agent.sh"
  },
  "exports": {
    "./logger": {
      "import": "./dist/e2e-infra/logger.js",
      "types": "./dist/e2e-infra/logger.d.ts"
    },
    "./types": {
      "import": "./dist/e2e-infra/types.js",
      "types": "./dist/e2e-infra/types.d.ts"
    },
    "./report": {
      "import": "./dist/e2e-infra/report.js",
      "types": "./dist/e2e-infra/report.d.ts"
    },
    "./llm-judge": {
      "import": "./dist/e2e-infra/llm-judge.js",
      "types": "./dist/e2e-infra/llm-judge.d.ts"
    },
    "./docker-manager": {
      "import": "./dist/e2e-infra/docker-manager.js",
      "types": "./dist/e2e-infra/docker-manager.d.ts"
    },
    "./nanoclaw-smoke": {
      "import": "./dist/e2e-infra/nanoclaw-smoke.js",
      "types": "./dist/e2e-infra/nanoclaw-smoke.d.ts"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@sinclair/typebox": "^0.34.0",
    "dotenv": "^16.0.0",
    "js-yaml": "^4.0.0",
    "pg": "^8.13.0",
    "winston": "^3.0.0",
    "yargs": "^17.0.0"
  },
  "devDependencies": {
    "@moltzap/openclaw-channel": "workspace:*",
    "@moltzap/protocol": "workspace:*",
    "@moltzap/server-core": "workspace:*",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/js-yaml": "^4.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "@types/yargs": "^17.0.0",
    "kysely": "^0.27.0",
    "openclaw": "2026.3.31",
    "testcontainers": "^10.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.18.0"
  }
}
