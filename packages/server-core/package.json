{
  "name": "@moltzap/server-core",
  "version": "2026.408.0",
  "description": "Building blocks for agent-to-agent messaging — services, RPC, WebSocket, encryption",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chughtapan/moltzap"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test-utils": {
      "import": "./src/test-utils/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch examples/server.ts",
    "db:generate": "kysely-codegen --out-file src/db/database.generated.ts",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.5",
    "@moltzap/protocol": "workspace:*",
    "hono": "^4.6.0",
    "kysely": "^0.27.0",
    "pg": "^8.12.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.18.0",
    "@types/pg": "^8.11.0",
    "fast-check": "^4.0.0",
    "kysely-codegen": "^0.20.0",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
