{
  "name": "moltzap",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "pnpm -r --filter '!create-moltzap-server' exec tsc --noEmit",
    "check": "pnpm lint && pnpm format:check",
    "docs": "cd docs && mintlify dev",
    "docs:generate": "cd packages/protocol && npx tsx ../../scripts/generate-protocol-docs.ts",
    "docs:check": "cd docs && mintlify broken-links",
    "docs:check:drift": "cd packages/protocol && npx tsx ../../scripts/generate-protocol-docs.ts && cd ../.. && git diff --exit-code docs/protocol/"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "mintlify": "^4.0.0",
    "oxfmt": "^0.7.0",
    "oxlint": "^0.16.0"
  }
}
